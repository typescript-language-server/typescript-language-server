    "compilerOptions": {
        "target": "esnext",
        "module": "esnext",
        "esModuleInterop": true,
        "noEmit": true,
        "allowSyntheticDefaultImports": true,
        "resolveJsonModule": true,
        "moduleResolution": "nodenext",
        "noLib": true,
        "types": [
            "fs-extra",
            "node",
        ]
    },
}
